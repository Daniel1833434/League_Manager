@page
@model Pesach_Project.Pages.ManageLeaguesModel
@{
    ViewData["Title"] = "ManageLeagues";
}
<p class="display-3">Manage @Model.LeagueName 🏀⚽🎾! </p>

<div class="card shadow-sm mb-4">
    <div class="card-body d-flex justify-content-between align-items-center">
        <div>
            <h5 class="card-title mb-1">🏷️ League Name</h5>
            <p class="card-text text-muted mb-0">
                Current name: <strong>@Model.LeagueName</strong>
            </p>
        </div>

        <form method="post" asp-page-handler="ChangeName">
            <input type="hidden" name="NewName" />

            <button type="submit"
                    onclick="return askName(this)"
                    class="btn btn-warning">
                ✏️ Change Name
            </button>
        </form>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-body text-center">
                <h3 class="card-title">👥 Players</h3>
                <p class="card-text">Click here to manage players</p>

                <a asp-page="/ManagePlayers" class="btn btn-primary">
                    🛠️ Manage Players
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-body text-center">
                <h3 class="card-title">🏆 Games</h3>
                <p class="card-text">Click here to manage games</p>

                <a asp-page="/ManageGames" class="btn btn-primary">
                    🛠️ Manage Games
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-body text-center">
                <h3 class="card-title">🏆 League Table</h3>
                <p class="card-text">Click here to view the league table</p>

                <a asp-page="/LeagueTable" class="btn btn-primary">
                    🏆 View League Table
                </a>
            </div>
        </div>
    </div>

</div>

<a asp-page="/Index" class="fw-bold text-decoration-none">Back to Home</a>

<script>
    function askName(button) {
        let newName = prompt("Enter the new League name:");

        if (newName == null) {
            return false;
        }

        newName = newName.trim();

        if (newName === "") {
            alert("Name cannot be empty.");
            return false;
        }

        let form = button.closest("form");

        form.querySelector('input[name="NewName"]').value = newName;

        return true;
    }
</script>