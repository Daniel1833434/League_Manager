@page
@model Pesach_Project.Pages.LoginModel
@{
    ViewData["Title"] = "Login";
}
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card lm-form-card">
                <div class="lm-form-header">
                    <h3 class="mb-0">Welcome Back</h3>
                    <p class="small mb-0">Log in to your account!</p>
                </div>
                <div class="lm-form-body">
                    <form method="post" onsubmit="return validateLogin()">

                        <div class="mb-3">
                            <label class="form-label fw-bold">User Name</label>
                            <input asp-for="Username" id="userName" class="form-control" placeholder="Enter username" oninput="userNameVal()" />
                            <div id="userNameMsg" class="text-danger small mt-1"></div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Password</label>
                            <input asp-for="Password" type="password" id="password" class="form-control" placeholder="Enter password" oninput="passwordVal()" />
                            <div id="passwordMsg" class="text-danger small mt-1"></div>
                            <div class="text-danger small mt-1">@Model.msg</div>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg">Login</button>
                            <button type="reset" class="btn btn-light text-muted" onclick="clearMsgs()">Clear Form</button>
                        </div>
                    </form>
                </div>
                <div class="lm-form-footer">
                    <p class="mb-0">New here? <a asp-page="/Registration" class="text-decoration-none fw-bold">Sign up and create an account</a></p>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function validateLogin() {
        var isUserNameValid = userNameVal();
        var isPasswordValid = passwordVal();

        return isUserNameValid && isPasswordValid;
    }

    function isLetter(ch) {
        return (ch >= "a" && ch <= "z") || (ch >= "A" && ch <= "Z");
    }

    function userNameVal() {
        var userName = document.getElementById("userName").value;
        var msgBox = document.getElementById("userNameMsg");
        if (userName.length == 0) {
            msgBox.innerHTML = "You must enter user name";
            return false;
        }
        if (!isLetter(userName[0])) {
            msgBox.innerHTML = "User name must start with a letter";
            return false;
        }
        msgBox.innerHTML = "";
        return true;
    }

    function passwordVal() {
        var pass = document.getElementById("password").value;
        var msgBox = document.getElementById("passwordMsg");

        if (pass.length < 7) {
            msgBox.innerHTML = "Password must contain at least 7 characters";
            return false;
        }
        msgBox.innerHTML = "";
        return true;
    }

    function clearMsgs() {
        var msgs = document.getElementsByClassName("text-danger");
        for(var i=0; i<msgs.length; i++) { msgs[i].innerHTML = ""; }
    }
</script>