@page
@model IndexModel
@using System.Data
@{
	ViewData["Title"] = "Home page";
}

<div class="text-center">
	@if (Model.UserName != null)
	{
		<h1 class="display-4">Welcome back to League Manager, @Model.UserName!</h1>
		<p class="lead">Manage your leagues, players and games easily.</p>

		@if (Model.dt != null && Model.dt.Rows.Count > 0)
		{
			<table class="table lm-table">
				<thead>
					<tr>
						@foreach (DataColumn column in Model.dt.Columns)
						{
							if (column.ColumnName == "Id")
							{
								continue;
							}
							<th>@column.ColumnName</th>
						}
						<th>Actions</th>
					</tr>
				</thead>
				<tbody>
					@foreach (DataRow row in Model.dt.Rows)
					{
						<tr>
							@foreach (DataColumn column in Model.dt.Columns)
							{
								if (column.ColumnName == "Id")
								{
									continue;
								}
								<td>@row[column]</td>
							}
							<td class="lm-actions">
								<form method="post" asp-page-handler="Manage">
									<input type="hidden" name="LeagueId" value="@row["Id"]" />
									<input type="hidden" name="LeagueName" value="@row["LeagueName"]" />

									<button type="submit" class="btn btn-warning btn-sm">
										Manage
									</button>
								</form>

								<form method="post" asp-page-handler="Delete">
									<input type="hidden" name="LeagueId" value="@row["Id"]" />

									<button type="submit" class="btn btn-danger btn-sm">
										Delete
									</button>
								</form>
							</td>
						</tr>
					}
				</tbody>
			</table>
		}
		else
		{
			<p class="text-muted">You do not have any leagues yet.</p>
		}

		<a class="btn btn-primary px-4 mt-3" asp-page="/CreateLeague">Create League</a>
	}
	else
	{
		<h1 class="display-4">Welcome to League Manager!</h1>
		<p class="lead">Create leagues, manage players and track games.</p>
		<p>Please <a asp-page="/Login" class="btn btn-primary px-4 ms-2">Login</a> to continue.</p>
	}

	<div class="card lm-form-card mt-4">
		<div class="lm-form-body">
			<div class="row align-items-center">
				<div class="col-md-5">
					<img src="~/Sports.jpg" asp-append-version="true" class="img-fluid rounded" />
				</div>

				<div class="col-md-7 text-md-start text-center mt-3 mt-md-0">
					<h3 class="card-title mb-3">🏆 League Manager</h3>

					<p class="card-text text-muted">
						League Manager helps you create sports leagues, manage players,
						record games and view the league table in one simple place.
					</p>
				</div>
			</div>
		</div>
	</div>

</div>
</div>